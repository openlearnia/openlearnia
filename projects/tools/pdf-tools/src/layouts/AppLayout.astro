---
import '../styles/global.css';
import tools from '../data/pdf-tools.json';
import { relatedExcept } from '../lib/relatedTools';

interface Props {
  title: string;
  description?: string;
  activeSlug?: string;
}

const SITE = 'https://pdf-tools.openlearnia.com';
const DEFAULT_DESCRIPTION =
  'Privacy-first PDF tools — merge, split, delete, reorder, rotate, watermark, and convert images ↔ PDF entirely in your browser. Nothing is uploaded.';

const {
  title,
  description = DEFAULT_DESCRIPTION,
  activeSlug,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE).href;
const pageTitle = title.includes('Openlearnia') ? title : `${title} | Openlearnia PDF Tools`;
const relatedTools = relatedExcept(SITE);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Openlearnia PDF Tools',
  url: SITE,
  description: DEFAULT_DESCRIPTION,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Organization',
    name: 'Openlearnia',
    url: 'https://openlearnia.com',
  },
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Openlearnia PDF Tools" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <meta name="theme-color" content="#0f1117" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <header>
      <p><strong><a href="/" style="color:inherit;text-decoration:none">Openlearnia PDF Tools</a></strong></p>
      <nav>
        <a href="/" class:list={{ active: !activeSlug }}>All tools</a>
        {tools.slice(0, 5).map((t) => (
          <a href={`/${t.slug}`} class:list={{ active: activeSlug === t.slug }}>{t.name}</a>
        ))}
        <a href="https://openlearnia.com">Openlearnia</a>
        <a href="https://github.com/openlearnia/pdf-tools">GitHub</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <nav class="related-tools" aria-label="Related tools">
      {relatedTools.map((t) => (
        <a href={t.href}>{t.name}</a>
      ))}
    </nav>
    <footer>
      <p>An <a href="https://openlearnia.com">Openlearnia</a> project — files never leave your device.</p>
      <p>© {new Date().getFullYear()} Openlearnia · <a href="https://openlearnia.com">openlearnia.com</a></p>
    </footer>
  </body>
</html>
