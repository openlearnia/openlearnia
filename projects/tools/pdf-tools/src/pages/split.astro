---
import AppLayout from '../layouts/AppLayout.astro';
import ToolShell from '../components/ToolShell.astro';
import DropZone from '../components/DropZone.astro';
import PageThumbGrid from '../components/PageThumbGrid.astro';
---
<AppLayout
  title="Split PDF — Openlearnia PDF Tools"
  description="Extract a page range into a new PDF — entirely in your browser."
  activeSlug="split"
>
  <ToolShell title="Split PDF" description="Extract a page range into a new PDF." slug="split">
    <DropZone label="Drop a PDF here or click to browse" />
    <p class="stats" id="file-hint">Choose a PDF to split</p>
    <div class="controls">
      <label>
        From page
        <input type="number" id="from-page" min="1" value="1" />
      </label>
      <label>
        To page
        <input type="number" id="to-page" min="1" value="1" />
      </label>
    </div>
    <p class="stats" id="selection-hint"></p>
    <p class="error" id="range-error" hidden></p>
    <PageThumbGrid id="thumb-grid" />
    <button id="download-btn" data-label="Download split.pdf" disabled>Download split.pdf</button>
  </ToolShell>
</AppLayout>
<script>
  import { initSplit } from '../scripts/split';
  initSplit();
</script>
