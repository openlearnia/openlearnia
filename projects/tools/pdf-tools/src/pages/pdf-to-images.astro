---
import AppLayout from '../layouts/AppLayout.astro';
import ToolShell from '../components/ToolShell.astro';
import DropZone from '../components/DropZone.astro';
import PageThumbGrid from '../components/PageThumbGrid.astro';
---
<AppLayout
  title="PDF to Images — Openlearnia PDF Tools"
  description="Export each PDF page as a JPEG and download a ZIP — entirely in your browser."
  activeSlug="pdf-to-images"
>
  <ToolShell title="PDF → Images" description="Render pages locally and download a ZIP of JPEGs." slug="pdf-to-images">
    <DropZone label="Drop a PDF here or click to browse" />
    <p class="stats" id="file-hint">Choose a PDF</p>
    <div class="controls">
      <label>
        Scale
        <select id="export-scale">
          <option value="1">1× (fast)</option>
          <option value="2" selected>2× (balanced)</option>
          <option value="3">3× (sharp)</option>
        </select>
      </label>
    </div>
    <PageThumbGrid id="thumb-grid" />
    <button id="download-btn" data-label="Download pages.zip" disabled>Download pages.zip</button>
  </ToolShell>
</AppLayout>
<script>
  import { initPdfToImages } from '../scripts/pdf-to-images';
  initPdfToImages();
</script>
