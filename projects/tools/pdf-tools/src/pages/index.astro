---
import AppLayout from '../layouts/AppLayout.astro';
import tools from '../data/pdf-tools.json';

const categories = [...new Set(tools.map((t) => t.category))];
---
<AppLayout title="PDF Tools — Openlearnia" description="Privacy-first PDF utilities processed entirely in your browser.">
  <div class="privacy-badge">All tools run locally — your files never leave your device</div>
  <h1>PDF Tools</h1>
  <p>Free, private PDF utilities. Pick a tool below — no upload, no account.</p>

  {categories.map((category) => (
    <section>
      <h2>{category}</h2>
      <div class="tool-grid">
        {tools.filter((t) => t.category === category).map((tool) => (
          <a class="tool-card" href={`/${tool.slug}`}>
            <div class="category">{category}</div>
            <h3>{tool.name}</h3>
            <p>{tool.description}</p>
          </a>
        ))}
      </div>
    </section>
  ))}
</AppLayout>
